{
  "name": "vibelearn",
  "displayName": "VibeLearn",
  "description": "Learning-first AI coding assistant. Hints and guiding questions instead of full solutions.",
  "version": "0.0.1",
  "publisher": "vibelearn",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "vibelearn.openChat",
        "title": "VibeLearn: Open Chat"
      },
      {
        "command": "vibelearn.setApiKey",
        "title": "VibeLearn: Set API Key"
      },
      {
        "command": "vibelearn.clearApiKey",
        "title": "VibeLearn: Clear API Key"
      },
      {
        "command": "vibelearn.reviewSelection",
        "title": "VibeLearn: Review Selected Code"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "vibelearn.reviewSelection",
          "when": "editorHasSelection",
          "group": "1_modification"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vibelearn",
          "title": "VibeLearn",
          "icon": "media/vibelearn.svg"
        }
      ]
    },
    "views": {
      "vibelearn": [
        {
          "type": "webview",
          "id": "vibelearn.chatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "VibeLearn",
      "properties": {
        "vibelearn.provider": {
          "type": "string",
          "default": "openai",
          "enum": ["openai", "anthropic", "gemini", "ollama"],
          "enumDescriptions": [
            "OpenAI (GPT models)",
            "Anthropic (Claude models)",
            "Google Gemini",
            "Ollama (local models, no API key)"
          ],
          "description": "AI provider used by VibeLearn."
        },
        "vibelearn.model": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Model name for the selected provider (e.g. gpt-4o-mini, claude-sonnet-4-6, gemini-1.5-pro, llama3)."
        },
        "vibelearn.helpLevel": {
          "type": "string",
          "default": "guided",
          "enum": ["strict", "guided", "assist", "full"],
          "enumDescriptions": [
            "Strict: only questions and concept hints, never code.",
            "Guided: hints and small steps, partial code only when asked.",
            "Assist: hints first, but willing to show full code on request.",
            "Full: behaves like a normal assistant, gives complete answers."
          ],
          "description": "How much the assistant teaches vs. answers directly."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "tsc -p ./ && node --test out/ai/promptBuilder.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
